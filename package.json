{
  "name": "1-minute-workout-extension",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "dev": "vite dev && vite build --config vite.background.config.js",
    "build:dev": "vite build --mode development && vite build --config vite.background.config.js --mode development",
    "devext": "nodemon --watch src --watch static --exec \"npm run build:dev\" -e json,css,html,svelte",
    "build": "vite build && vite build --config vite.background.config.js",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.47.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@sveltejs/vite-plugin-svelte-inspector": "^5.0.1",
    "@tailwindcss/postcss": "^4.1.15",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "svelte": "^5.41.1",
    "sveltekit-adapter-chrome-extension": "^2.0.1",
    "tailwindcss": "^4.1.15",
    "vite": "^7.1.11"
  },
  "type": "module",
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@tailwindcss/vite": "^4.1.15",
    "clsx": "^2.1.1",
    "daisyui": "^5.3.7",
    "lucide-svelte": "^0.546.0",
    "nodemon": "^3.1.10",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1"
  }
}
